# ─── Proxy Server ──────────────────────────────────────────────────────────────

# Port the proxy listens on (default: 8080)
MOEPT_PORT=8080

# ─── Lemonade NPU Server ──────────────────────────────────────────────────────

# Base URL of the Lemonade server API
MOEPT_SERVER__URL=http://localhost:13305/api/v1

# LLM model identifier used for completions
MOEPT_SERVER__LLM_MODEL=Qwen3.6-35B-A3B-MTP-GGUF

# Embedding model identifier used for semantic search
MOEPT_SERVER__EMBED_MODEL=embed-gemma-300m-FLM

# ─── Agentic Loop Tuning ──────────────────────────────────────────────────────

# Last N steps kept in full detail for immediate reasoning context
MOEPT_AGENTIC__KEEP_FULL_STEPS=3

# Steps before this index get compressed/evicted
MOEPT_AGENTIC__ARCHIVE_THRESHOLD=3

# Hard cap on optimized context window (characters)
MOEPT_AGENTIC__MAX_OPTIMIZED_CHARS=12000

# Keep full thinking content for last N steps
MOEPT_AGENTIC__THINKING_PROTECT_RECENT=2

# Session inactivity timeout in seconds before cleanup
MOEPT_AGENTIC__SESSION_TIMEOUT=3600

# ─── Code Chunking ─────────────────────────────────────────────────────────────

# Maximum characters per code chunk for semantic indexing
MOEPT_CODE_CHUNKING__CHUNK_MAX_CHARS=1500

# Number of top relevant chunks to retrieve during optimization
MOEPT_CODE_CHUNKING__TOP_K_CHUNKS=5

# Minimum embedding similarity score to include a chunk
MOEPT_CODE_CHUNKING__MIN_CHUNK_SCORE=0.05

# ─── Cache ─────────────────────────────────────────────────────────────────────

# Maximum number of embeddings to keep in memory cache
MOEPT_CACHE__EMBED_CACHE_MAX=512

# Path to LanceDB vector database data directory
MOEPT_CACHE__LANCEDB_PATH=~/.moeptimizer/lancedb
